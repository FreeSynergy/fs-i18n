# fs-channel-matrix — Matrix-Channel-Adapter Übersetzungen (Deutsch)

channel-matrix-capability-name = Matrix-Channel-Adapter

channel-matrix-error-connect       = Verbindung zum Matrix-Homeserver fehlgeschlagen: { $reason }
channel-matrix-error-send          = Nachricht an { $room } konnte nicht gesendet werden: { $reason }
channel-matrix-error-receive       = Matrix-Nachrichten konnten nicht empfangen werden: { $reason }
channel-matrix-error-not-connected = Matrix-Adapter ist nicht verbunden.

channel-matrix-info-connected = Mit Matrix verbunden als { $user }.

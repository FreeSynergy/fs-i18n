mail-wizard-oidc-secret-placeholder  = Client secret

# ── Buttons ───────────────────────────────────────────────────────────────────

mail-wizard-btn-next      = Next
mail-wizard-btn-skip-oidc = Skip (local accounts)
mail-wizard-btn-confirm   = Apply Configuration
mail-wizard-btn-use-acme  = Use ACME (recommended)
mail-wizard-btn-use-manual = Use manual certificate

# ── DNS hints ─────────────────────────────────────────────────────────────────

mail-wizard-dns-mx-hint    = MX  — Point your MX record at this server's hostname
mail-wizard-dns-spf-hint   = SPF — Add: v=spf1 mx ~all
mail-wizard-dns-dkim-hint  = DKIM — Generated by Stalwart on first start; add to DNS
mail-wizard-dns-dmarc-hint = DMARC — Add: v=DMARC1; p=none; rua=mailto:admin@{$domain}
mail-wizard-dns-note       = Note: DNS propagation may take up to 48 hours.

# ── Error messages ────────────────────────────────────────────────────────────

mail-wizard-error-domain-empty          = Domain must not be empty.
mail-wizard-error-domain-spaces         = Domain must not contain spaces.
mail-wizard-error-admin-email-invalid   = A valid e-mail address is required (must contain @).
mail-wizard-error-tls-paths-empty       = Both certificate and key paths are required for manual TLS.
mail-wizard-error-tls-required          = TLS must be configured (ACME or manual) before proceeding.
mail-wizard-error-oidc-fields-required  = Issuer URL, client ID, and client secret are all required.
mail-wizard-error-oidc-required         = Configure OIDC or press Skip to use local accounts.
mail-wizard-error-domain-required       = Domain and postmaster address are required.
mail-wizard-error-config-incomplete     = Configuration is incomplete — check all previous steps.
mail-wizard-error-wrong-step            = This action is not available at the current step.
mail-wizard-error-skip-invalid-step     = Skip is only available on the OIDC step.

# ── Status / events ───────────────────────────────────────────────────────────

mail-adapter-registered   = Stalwart Mail adapter registered in fs-registry.
mail-adapter-deregistered = Stalwart Mail adapter deregistered from fs-registry.
